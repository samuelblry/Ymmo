        SERIAL id_agence PK
        VARCHAR nom_agence
        VARCHAR ville
        VARCHAR code_postal
        TEXT adresse
        VARCHAR telephone
        VARCHAR email
        TEXT description
        VARCHAR image_url
    }
    BIENS {
        SERIAL id_bien PK
