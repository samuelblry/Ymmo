    USER {
        SERIAL id_user PK
        VARCHAR nom
        VARCHAR prenom
        VARCHAR email UK
        VARCHAR password_hash
        VARCHAR telephone
        TIMESTAMP date_inscription
    }
    EMPLOYES {
        SERIAL id_employe PK
        VARCHAR nom
        VARCHAR prenom
        VARCHAR email UK
        VARCHAR password_hash
        VARCHAR telephone
        INT id_role FK
        INT id_agence FK
