        TIMESTAMP date_modification
    }
    IMAGES {
        SERIAL id_image PK
        VARCHAR url
        INT id_bien FK
        BOOLEAN is_main
    }
    ARTICLES {
        SERIAL id_article PK
        INT id_auteur FK
        VARCHAR titre
        TEXT contenu
        VARCHAR image_url
        VARCHAR statut
        TIMESTAMP date_envoi
    }
    MESSAGES {
        SERIAL id_message PK
        INT id_agence_dest FK
        VARCHAR nom
        VARCHAR prenom
        VARCHAR email
        VARCHAR telephone
        VARCHAR sujet
        TEXT contenu
        BOOLEAN lu
        TIMESTAMP date_envoi
    }
    STATS_BIENS {
        SERIAL id_stat PK
        INT id_bien FK
        INT nb_vues
        INT nb_clicks
        INT nb_likes
        FLOAT score_popularite
        TIMESTAMP last_update
    }
    STATS_ARTICLES {
        SERIAL id_stat PK
        INT id_article FK
        INT nb_vues
        INT nb_likes
        FLOAT score_popularite
        TIMESTAMP last_update
    }
    FAVORIS_BIENS {
        SERIAL id_favori PK
        INT id_user FK
        INT id_bien FK
        TIMESTAMP date_ajout
    }
    FAVORIS_ARTICLES {
        SERIAL id_favori PK
        INT id_user FK
        INT id_article FK
        TIMESTAMP date_ajout
    }
    LIKES {
        SERIAL id_like PK
        INT id_user FK
        INT id_bien FK
        INT id_article FK
        TIMESTAMP date_ajout
    }
    LOGS {
        SERIAL id_log PK
        INT id_employe FK
        VARCHAR action
        VARCHAR ip_adresse
        TEXT user_agent
        BOOLEAN succes
        TIMESTAMP date_heure
    }

